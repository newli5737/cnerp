# =============================================================================
# CNERP — ERP vận hành Trung–Việt
# Copy to .env
# =============================================================================

NODE_ENV=production
API_PORT=4050
API_PREFIX=api/v1
CORS_ORIGIN=https://cnerp.dosutech.site

DATABASE_URL="postgresql://postgres:test1234@localhost:5432/cnerp?schema=public"

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=cnerp-dev-jwt-secret-change-me
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=cnerp-dev-refresh-secret-change-me
JWT_REFRESH_EXPIRES_IN=7d

VITE_API_BASE_URL=https://api-cnerp.dosutech.site/api/v1

SEED_ADMIN_EMAIL=admin@cnerp.local
SEED_ADMIN_PASSWORD=Admin@123
