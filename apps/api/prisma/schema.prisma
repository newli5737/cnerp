generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(uuid())
  code      String   @unique
  nameVi    String   @map("name_vi")
  nameZh    String?  @map("name_zh")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users              User[]
  roles              Role[]
  partners           Partner[]
  warehouses         Warehouse[]
  products           Product[]
  productAttributes  ProductAttribute[]
  stockBalances      StockBalance[]
  stockMoves         StockMove[]
  salesOrders        SalesOrder[]
  purchaseOrders     PurchaseOrder[]
  invoices           Invoice[]
  invoicePayments    InvoicePayment[]
  cashVouchers       CashVoucher[]
  bankVouchers       BankVoucher[]
  documentSequences  DocumentSequence[]
  auditLogs          AuditLog[]

  @@map("companies")
}

model User {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  email        String
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company   Company    @relation(fields: [companyId], references: [id])
  userRoles UserRole[]

  @@unique([companyId, email])
  @@map("users")
}

model Permission {
  id          String @id @default(uuid())
  code        String @unique
  nameVi      String @map("name_vi")
  nameZh      String? @map("name_zh")
  module      String

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Role {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  code      String
  nameVi    String   @map("name_vi")
  nameZh    String?  @map("name_zh")
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company           Company          @relation(fields: [companyId], references: [id])
  rolePermissions   RolePermission[]
  userRoles         UserRole[]

  @@unique([companyId, code])
  @@map("roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Partner {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  code      String
  nameVi    String   @map("name_vi")
  nameZh    String?  @map("name_zh")
  type      String
  taxCode   String?  @map("tax_code")
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company        Company         @relation(fields: [companyId], references: [id])
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  cashVouchers   CashVoucher[]
  bankVouchers   BankVoucher[]

  @@unique([companyId, code])
  @@map("partners")
}

model Warehouse {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  code      String
  nameVi    String   @map("name_vi")
  nameZh    String?  @map("name_zh")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company        Company         @relation(fields: [companyId], references: [id])
  stockBalances  StockBalance[]
  stockMoves     StockMove[]     @relation("FromWarehouse")
  transferIns    StockMove[]     @relation("ToWarehouse")
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]

  @@unique([companyId, code])
  @@map("warehouses")
}

model ProductAttribute {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  code        String
  nameVi      String   @map("name_vi")
  nameZh      String?  @map("name_zh")
  dataType    String   @map("data_type")
  optionsJson Json?    @map("options_json")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company                 @relation(fields: [companyId], references: [id])
  values  ProductAttributeValue[]

  @@unique([companyId, code])
  @@map("product_attributes")
}

model Product {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  sku       String
  nameVi    String   @map("name_vi")
  nameZh    String?  @map("name_zh")
  unit      String   @default("Cái")
  salePrice Decimal  @default(0) @map("sale_price") @db.Decimal(18, 2)
  costPrice Decimal  @default(0) @map("cost_price") @db.Decimal(18, 2)
  vatRate   Decimal  @default(10) @map("vat_rate") @db.Decimal(5, 2)
  minStock  Decimal  @default(0) @map("min_stock") @db.Decimal(18, 4)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company         Company                 @relation(fields: [companyId], references: [id])
  attributeValues ProductAttributeValue[]
  stockBalances   StockBalance[]
  stockMoveLines  StockMoveLine[]
  salesOrderLines SalesOrderLine[]
  purchaseLines   PurchaseOrderLine[]

  @@unique([companyId, sku])
  @@map("products")
}

model ProductAttributeValue {
  id          String  @id @default(uuid())
  productId   String  @map("product_id")
  attributeId String  @map("attribute_id")
  valueText   String? @map("value_text")
  valueNumber Decimal? @map("value_number") @db.Decimal(18, 4)

  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId])
  @@map("product_attribute_values")
}

model StockBalance {
  id          String  @id @default(uuid())
  companyId   String  @map("company_id")
  warehouseId String  @map("warehouse_id")
  productId   String  @map("product_id")
  qty         Decimal @default(0) @db.Decimal(18, 4)

  company   Company   @relation(fields: [companyId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
  @@index([companyId])
  @@map("stock_balances")
}

model StockMove {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  warehouseId     String   @map("warehouse_id")
  toWarehouseId   String?  @map("to_warehouse_id")
  moveType        String   @map("move_type")
  referenceType   String?  @map("reference_type")
  referenceId     String?  @map("reference_id")
  code            String
  moveDate        DateTime @map("move_date") @db.Date
  status          String   @default("POSTED")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at")

  company     Company         @relation(fields: [companyId], references: [id])
  warehouse   Warehouse       @relation("FromWarehouse", fields: [warehouseId], references: [id])
  toWarehouse Warehouse?      @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  lines       StockMoveLine[]

  @@unique([companyId, code])
  @@index([companyId, referenceType, referenceId])
  @@map("stock_moves")
}

model StockMoveLine {
  id          String  @id @default(uuid())
  stockMoveId String  @map("stock_move_id")
  productId   String  @map("product_id")
  qty         Decimal @db.Decimal(18, 4)
  unitCost    Decimal @default(0) @map("unit_cost") @db.Decimal(18, 4)
  lineNo      Int     @map("line_no")

  stockMove StockMove @relation(fields: [stockMoveId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@index([stockMoveId])
  @@map("stock_move_lines")
}

model SalesOrder {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  code           String
  partnerId      String   @map("partner_id")
  warehouseId    String   @map("warehouse_id")
  orderDate      DateTime @map("order_date") @db.Date
  status         String   @default("DRAFT")
  subtotalAmount Decimal  @default(0) @map("subtotal_amount") @db.Decimal(18, 2)
  vatAmount      Decimal  @default(0) @map("vat_amount") @db.Decimal(18, 2)
  totalAmount    Decimal  @default(0) @map("total_amount") @db.Decimal(18, 2)
  note           String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company   Company          @relation(fields: [companyId], references: [id])
  partner   Partner          @relation(fields: [partnerId], references: [id])
  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  lines     SalesOrderLine[]
  invoices  Invoice[]

  @@unique([companyId, code])
  @@map("sales_orders")
}

model SalesOrderLine {
  id           String  @id @default(uuid())
  salesOrderId String  @map("sales_order_id")
  productId    String  @map("product_id")
  qty          Decimal @db.Decimal(18, 4)
  unitPrice    Decimal @map("unit_price") @db.Decimal(18, 2)
  vatRate      Decimal @default(10) @map("vat_rate") @db.Decimal(5, 2)
  vatAmount    Decimal @default(0) @map("vat_amount") @db.Decimal(18, 2)
  lineAmount   Decimal @map("line_amount") @db.Decimal(18, 2)
  lineTotal    Decimal @default(0) @map("line_total") @db.Decimal(18, 2)
  lineNo       Int     @map("line_no")

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@map("sales_order_lines")
}

model PurchaseOrder {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  code        String
  partnerId   String   @map("partner_id")
  warehouseId String   @map("warehouse_id")
  orderDate   DateTime @map("order_date") @db.Date
  status      String   @default("DRAFT")
  totalAmount Decimal  @default(0) @map("total_amount") @db.Decimal(18, 2)
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company   Company             @relation(fields: [companyId], references: [id])
  partner   Partner             @relation(fields: [partnerId], references: [id])
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  lines     PurchaseOrderLine[]
  invoices  Invoice[]

  @@unique([companyId, code])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              String  @id @default(uuid())
  purchaseOrderId String  @map("purchase_order_id")
  productId       String  @map("product_id")
  qty             Decimal @db.Decimal(18, 4)
  unitCost        Decimal @map("unit_cost") @db.Decimal(18, 2)
  lineAmount      Decimal @map("line_amount") @db.Decimal(18, 2)
  lineNo          Int     @map("line_no")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_lines")
}

model Invoice {
  id              String    @id @default(uuid())
  companyId       String    @map("company_id")
  partnerId       String    @map("partner_id")
  type            String
  code            String
  invoiceDate     DateTime  @map("invoice_date") @db.Date
  dueDate         DateTime? @map("due_date") @db.Date
  totalAmount     Decimal   @map("total_amount") @db.Decimal(18, 2)
  paidAmount      Decimal   @default(0) @map("paid_amount") @db.Decimal(18, 2)
  status          String    @default("POSTED")
  salesOrderId    String?   @map("sales_order_id")
  purchaseOrderId String?   @map("purchase_order_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  company       Company          @relation(fields: [companyId], references: [id])
  partner       Partner          @relation(fields: [partnerId], references: [id])
  salesOrder    SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  purchaseOrder PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  payments      InvoicePayment[]

  @@unique([companyId, code])
  @@map("invoices")
}

model InvoicePayment {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  invoiceId     String   @map("invoice_id")
  cashVoucherId String?  @map("cash_voucher_id")
  bankVoucherId String?  @map("bank_voucher_id")
  amount        Decimal  @db.Decimal(18, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  company     Company      @relation(fields: [companyId], references: [id])
  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  cashVoucher CashVoucher? @relation(fields: [cashVoucherId], references: [id])
  bankVoucher BankVoucher? @relation(fields: [bankVoucherId], references: [id])

  @@map("invoice_payments")
}

model CashVoucher {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  code         String
  type         String
  voucherDate  DateTime @map("voucher_date") @db.Date
  partnerId    String?  @map("partner_id")
  amount       Decimal  @db.Decimal(18, 2)
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")

  company  Company          @relation(fields: [companyId], references: [id])
  partner  Partner?         @relation(fields: [partnerId], references: [id])
  payments InvoicePayment[]

  @@unique([companyId, code])
  @@map("cash_vouchers")
}

model BankVoucher {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  code         String
  type         String
  voucherDate  DateTime @map("voucher_date") @db.Date
  partnerId    String?  @map("partner_id")
  amount       Decimal  @db.Decimal(18, 2)
  note         String?
  createdAt    DateTime @default(now()) @map("created_at")

  company  Company          @relation(fields: [companyId], references: [id])
  partner  Partner?         @relation(fields: [partnerId], references: [id])
  payments InvoicePayment[]

  @@unique([companyId, code])
  @@map("bank_vouchers")
}

model DocumentSequence {
  id        String @id @default(uuid())
  companyId String @map("company_id")
  docType   String @map("doc_type")
  year      Int
  lastNumber Int   @default(0) @map("last_number")

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, docType, year])
  @@map("document_sequences")
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String?  @map("company_id")
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  meta       Json?
  createdAt  DateTime @default(now()) @map("created_at")

  company Company? @relation(fields: [companyId], references: [id])

  @@map("audit_logs")
}
